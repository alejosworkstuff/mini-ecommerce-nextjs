# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: Sentry (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# App
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_URL=ws://localhost:4001

# Redis (optional — defaults to redis://localhost:6379; in-memory Map if unset)
REDIS_URL=redis://localhost:6379

# Postgres (Phase 6 — Prisma; local Docker: postgresql://postgres:postgres@localhost:5432/mini_ecommerce)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mini_ecommerce

# Stripe Checkout (test mode) — optional; without these keys checkout uses the local demo path
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
